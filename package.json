{
  "name": "dianxiaoer-shop-manager",
  "version": "1.3.5",
  "description": "店小二网店管家 - 网店管理桌面工具",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win",
    "dist:dir": "electron-vite build && electron-builder --win --dir",
    "publish": "electron-vite build && electron-builder --win --publish always",
    "hot-update": "node scripts/build-hot-update.js",
    "hot-update:publish": "node scripts/build-hot-update.js --upload",
    "publish:hot": "node scripts/build-hot-update.js --upload",
    "test": "vitest run",
    "test:watch": "vitest",
    "publish:full": "node scripts/publish-full.js"
  },
  "build": {
    "appId": "com.dianxiaoer.shop-manager",
    "productName": "店小二网店管家",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "afterPack": "./scripts/after-pack.js",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "店小二网店管家",
      "language": 2052,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico"
    },
    "publish": {
      "provider": "generic",
      "url": "http://150.158.54.108:3001/updates"
    },
    "artifactName": "dianxiaoer-setup-${version}.${ext}"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.13.7",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "ssh2": "^1.17.0",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}